# ==============================
# FranClean Production Environment
# ==============================
# Copy this as .env on the VPS in the project root

# PostgreSQL
POSTGRES_USER=franclean
POSTGRES_PASSWORD=franclean_Pr0d_S3cret!
POSTGRES_DB=franclean_db
POSTGRES_PORT=5434

# Frontend (nginx container exposed port)
FRONTEND_PORT=8081

# JWT Secret (CHANGE THIS to a random string!)
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string_here

# Server port (internal, don't change)
PORT=3000
