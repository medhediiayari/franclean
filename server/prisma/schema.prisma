datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

// ── Users ───────────────────────────────────────────────
enum Role {
  admin
  agent
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String   @default("")
  role      Role     @default(agent)
  avatar    String?
  isActive  Boolean  @default(true)
  canRefuseEvents Boolean @default(true)
  createdAt DateTime @default(now())

  // Relations
  assignedEvents EventAgent[]
  shifts         EventShift[]
  attendances    Attendance[]
  historyEntries EventHistory[]

  @@map("users")
}

// ── Events ──────────────────────────────────────────────
enum EventStatus {
  planifie
  en_cours
  termine
  a_reattribuer
  annule
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String      @default("")
  client      String?
  clientPhone String?
  site        String?
  color       String      @default("#6366F1")
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  address     String      @default("")
  latitude    Float?
  longitude   Float?
  geoRadius   Int         @default(200)
  hourlyRate  Float?      // Prix unitaire HT par heure
  status      EventStatus @default(planifie)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  shifts      EventShift[]
  agents      EventAgent[]
  history     EventHistory[]
  attendances Attendance[]

  @@map("events")
}

// ── Event ↔ Agent (many-to-many with response) ─────────
enum AgentResponse {
  pending
  accepted
  refused
}

model EventAgent {
  id       String        @id @default(cuid())
  eventId  String
  agentId  String
  response AgentResponse @default(pending)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agent User  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([eventId, agentId])
  @@map("event_agents")
}

// ── Event Shifts ────────────────────────────────────────
model EventShift {
  id        String   @id @default(cuid())
  eventId   String
  agentId   String?
  date      DateTime @db.Date
  startTime String   // HH:mm
  endTime   String   // HH:mm

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agent       User?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  attendances Attendance[]

  @@map("event_shifts")
}

// ── Event History ───────────────────────────────────────
model EventHistory {
  id        String   @id @default(cuid())
  eventId   String
  action    String
  userId    String
  details   String?
  timestamp DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("event_history")
}

// ── Attendance ──────────────────────────────────────────
enum AttendanceStatus {
  en_attente
  valide
  refuse
  suspect
}

model Attendance {
  id      String @id @default(cuid())
  eventId String
  shiftId String?
  agentId String
  date    DateTime @db.Date

  // Check-in
  checkInTime          DateTime?
  checkInPhotoUrl      String?
  checkInLatitude      Float?
  checkInLongitude     Float?
  checkInLocationValid Boolean?

  // Check-out
  checkOutTime          DateTime?
  checkOutPhotoUrl      String?
  checkOutLatitude      Float?
  checkOutLongitude     Float?
  checkOutLocationValid Boolean?

  // Calculated
  hoursWorked Float?

  // Validation
  status        AttendanceStatus @default(en_attente)
  validatedBy   String?
  validatedAt   DateTime?
  refusalReason String?

  // Flags
  isSuspect      Boolean  @default(false)
  suspectReasons String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shift EventShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  agent User       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("attendances")
}

// ── Clients ─────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String?
  phone     String?
  address   String?
  notes     String?

  // Informations juridiques (contrat)
  siret             String?  // 14 chiffres
  siren             String?  // 9 chiffres
  formeJuridique    String?  // SARL, SAS, SA, etc.
  tvaNumber         String?  // N° TVA intracommunautaire
  representantLegal String?  // Nom du représentant légal
  representantRole  String?  // Qualité (Gérant, Président...)
  codeApe           String?  // Code APE/NAF
  capitalSocial     String?  // Capital social
  rcs               String?  // RCS (numéro + ville)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites ClientSite[]

  @@map("clients")
}

model ClientSite {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  address   String   @default("")
  latitude  Float?
  longitude Float?
  geoRadius   Int      @default(200)
  hourlyRate  Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_sites")
}

// ── Agent Payments (virements / acomptes) ───────────────
model AgentPayment {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // 'virement' | 'acompte'
  amount    Float
  date      String   // YYYY-MM-DD (date du paiement)
  periodStart String // YYYY-MM-DD (début période associée)
  periodEnd   String // YYYY-MM-DD (fin période associée)
  note      String?
  createdAt DateTime @default(now())

  @@map("agent_payments")
}
