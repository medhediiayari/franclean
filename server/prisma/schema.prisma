datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

// ── Users ───────────────────────────────────────────────
enum Role {
  admin
  agent
  client
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String   @default("")
  role      Role     @default(agent)
  avatar    String?
  isActive  Boolean  @default(true)
  canRefuseEvents Boolean @default(true)
  agentPercentage Float?  // Pourcentage agent pour calcul facturation
  clientId  String?
  isMainAccount Boolean @default(false)  // True pour le compte client principal
  createdAt DateTime @default(now())

  // Relations
  assignedEvents    EventAgent[]
  shifts            EventShift[]
  attendances       Attendance[]
  historyEntries    EventHistory[]
  pushSubscriptions PushSubscription[]
  linkedClient      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedSites     ClientUserSite[]

  @@map("users")
}

// ── Events ──────────────────────────────────────────────
enum EventStatus {
  planifie
  en_cours
  termine
  a_reattribuer
  annule
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String      @default("")
  client      String?
  clientPhone String?
  site        String?
  color       String      @default("#6366F1")
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  address     String      @default("")
  latitude    Float?
  longitude   Float?
  geoRadius   Int         @default(200)
  hourlyRate  Float?      // Prix unitaire HT par heure
  breakHours  Float       @default(0)  // Heures de pause déduites du total
  status      EventStatus @default(planifie)
  isDraft     Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  shifts      EventShift[]
  agents      EventAgent[]
  history     EventHistory[]
  attendances Attendance[]
  draftVersions EventDraftVersion[]

  @@map("events")
}

// ── Event ↔ Agent (many-to-many with response) ─────────
enum AgentResponse {
  pending
  accepted
  refused
}

model EventAgent {
  id       String        @id @default(cuid())
  eventId  String
  agentId  String
  response AgentResponse @default(pending)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agent User  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([eventId, agentId])
  @@map("event_agents")
}

// ── Event Shifts ────────────────────────────────────────
model EventShift {
  id        String   @id @default(cuid())
  eventId   String
  agentId   String?
  date      DateTime @db.Date
  startTime String   // HH:mm
  endTime   String   // HH:mm

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agent       User?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  attendances Attendance[]

  @@map("event_shifts")
}

// ── Event Draft Versions (snapshots) ────────────────────
model EventDraftVersion {
  id          String   @id @default(cuid())
  eventId     String
  versionNum  Int      @default(1)
  snapshot    String   // JSON snapshot of event data at this version
  label       String   @default("")  // optional label e.g. "v1", "Avant modif horaires"
  createdBy   String
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_draft_versions")
}

// ── Event History ───────────────────────────────────────
model EventHistory {
  id        String   @id @default(cuid())
  eventId   String
  action    String
  userId    String
  details   String?
  timestamp DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("event_history")
}

// ── Attendance ──────────────────────────────────────────
enum AttendanceStatus {
  en_attente
  valide
  refuse
  suspect
}

model Attendance {
  id      String @id @default(cuid())
  eventId String
  shiftId String?
  agentId String
  date    DateTime @db.Date

  // Check-in
  checkInTime          DateTime?
  checkInPhotoUrl      String?
  checkInLatitude      Float?
  checkInLongitude     Float?
  checkInLocationValid Boolean?

  // Check-out
  checkOutTime          DateTime?
  checkOutPhotoUrl      String?
  checkOutLatitude      Float?
  checkOutLongitude     Float?
  checkOutLocationValid Boolean?

  // Calculated
  hoursWorked  Float?
  billedHours  Float?

  // Validation
  status        AttendanceStatus @default(en_attente)
  validatedBy   String?
  validatedAt   DateTime?
  refusalReason String?

  // Flags
  isSuspect      Boolean  @default(false)
  suspectReasons String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shift  EventShift?        @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  agent  User               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  photos AttendancePhoto[]

  @@map("attendances")
}

// ── Attendance Photos (preuves de travail) ──────────────
model AttendancePhoto {
  id           String   @id @default(cuid())
  attendanceId String
  photoUrl     String
  caption      String?
  createdAt    DateTime @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("attendance_photos")
}

// ── Clients ─────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String?
  phone     String?
  address   String?
  notes     String?

  // Informations juridiques (contrat)
  siret             String?  // 14 chiffres
  siren             String?  // 9 chiffres
  formeJuridique    String?  // SARL, SAS, SA, etc.
  tvaNumber         String?  // N° TVA intracommunautaire
  representantLegal String?  // Nom du représentant légal
  representantRole  String?  // Qualité (Gérant, Président...)
  codeApe           String?  // Code APE/NAF
  capitalSocial     String?  // Capital social
  rcs               String?  // RCS (numéro + ville)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites ClientSite[]
  users User[]

  @@map("clients")
}

model ClientSite {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  address   String   @default("")
  latitude  Float?
  longitude Float?
  geoRadius   Int      @default(200)
  hourlyRate  Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userAccess ClientUserSite[]

  @@map("client_sites")
}

// ── Client User ↔ Site access (sous-comptes) ────────────
model ClientUserSite {
  id           String @id @default(cuid())
  userId       String
  clientSiteId String

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  site ClientSite @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)

  @@unique([userId, clientSiteId])
  @@map("client_user_sites")
}

// ── Agent Payments (virements / acomptes) ───────────────
model AgentPayment {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // 'virement' | 'acompte'
  amount    Float
  date      String   // YYYY-MM-DD (date du paiement)
  periodStart String // YYYY-MM-DD (début période associée)
  periodEnd   String // YYYY-MM-DD (fin période associée)
  note      String?
  createdAt DateTime @default(now())

  @@map("agent_payments")
}

// ── Email Notification Rules ────────────────────────────
model EmailNotificationRule {
  id          String   @id @default(cuid())
  type        String   // rule type key (see below)
  enabled     Boolean  @default(true)
  smsEnabled  Boolean  @default(false)
  recipients  String[] @default([]) // email addresses; empty = all admins
  threshold   Int      @default(0)  // minutes or days depending on type
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type])
  @@map("email_notification_rules")
}

// ── Email Log (sent emails history) ─────────────────────
model EmailLog {
  id         String   @id @default(cuid())
  ruleType   String
  recipient  String
  subject    String
  channel    String   @default("email") // "email" or "sms"
  entityId   String?  // eventId, attendanceId, etc.
  sentAt     DateTime @default(now())

  @@map("email_logs")
}

// ── SMS Config (Twilio) ─────────────────────────────────
model SmsConfig {
  id          String   @id @default("singleton")
  accountSid  String   @default("")
  authToken   String   @default("")
  phoneNumber String   @default("")
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("sms_config")
}

// ── App Settings (white-label / identité) ───────────────
model AppSettings {
  id             String   @id @default("singleton")
  appName        String   @default("Bipbip")
  appSubtitle    String   @default("Gestion RH")
  appLogoBase64  String?  // base64 data URL (data:image/…;base64,…)
  companyName    String?
  companyEmail   String?
  companyPhone   String?
  companyAddress String?
  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

// ── Push Subscriptions (Web Push API) ───────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
